#!/bin/bash

validar_password() {
  local pass=$1

  if [ ${#pass} -lt $MIN_LONGITUD ]; then
    echo "Error: La contraseña debe tener al menos $MIN_LONGITUD caracteres."
    return 1
  fi
  if [[ ! "$pass" =~ [A-Z] ]]; then
    echo "Error: La contraseña debe incluir al menos una mayúscula."
    return 1
  fi
  if [[ ! "$pass" =~ [0-9] ]]; then
    echo "Error: La contraseña debe incluir al menos un número."
    return 1
  fi
  return 0
}

if [ "$EUID" -ne 0 ]; then
  echo "Por favor, ejecuta este script como root o usando sudo."
  exit 1
fi

echo "--- Generador de Usuarios Nuevo ---"

read -p "Introduce el nombre del nuevo usuario: " NUEVO_USER

if id "$NUEVO_USER" &>/dev/null; then
  echo "El usuario '$NUEVO_USER' ya existe en el sistema."
  exit 1
fi

while true; do
  read -sp "Introduce la contraseña para $NUEVO_USER: " PASS_1
  echo
  read -sp "Confirma la contraseña: " PASS_2
  echo

  if [ "$PASS_1" != "$PASS_2" ]; then
    echo "Las contraseñas no coinciden. Inténtalo de nuevo."
    continue
  fi

  if validar_password "$PASS_1"; then
    break
  else
    echo "Intenta con una contraseña más fuerte."
  fi
done

read -p "Introduce el nombre completo del usuario: " NOMBRE_REAL

echo "Creando el usuario '$NUEVO_USER'..."

useradd -m -c "$NOMBRE_REAL" -s /bin/bash "$NUEVO_USER"

echo "$NUEVO_USER:$PASS_1" | chpasswd

if [ $? -eq 0 ]; then
  echo "--------------------------------------------------"
  echo "¡Éxito! El usuario $NUEVO_USER ha sido creado."
  echo "Directorio personal: /home/$NUEVO_USER"
  echo "--------------------------------------------------"
else
  echo "Hubo un error al procesar la creación del usuario."
  exit 1
fi

exit 0
