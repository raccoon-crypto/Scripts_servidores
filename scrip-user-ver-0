#!/bin/bash

MIN_LENGTH=8

function validar_password() {
    local pass=$1
    if [[ ${#pass} -lt $MIN_LENGTH ]]; then
        echo "Error: La contraseña debe tener al menos $MIN_LENGTH caracteres."
        return 1
    fi
    if [[ ! "$pass" =~ [A-Z] ]]; then echo "Error: Falta una mayúscula."; return 1; fi
    if [[ ! "$pass" =~ [a-z] ]]; then echo "Error: Falta una minúscula."; return 1; fi
    if [[ ! "$pass" =~ [0-9] ]]; then echo "Error: Falta un número."; return 1; fi
    return 0
}

if [[ $EUID -ne 0 ]]; then
   echo "Error: Este script debe ejecutarse con sudo o como root." 
   exit 1
fi

echo "=========================================="
echo "    GESTOR DE USUARIOS PRO (CUOTAS + SUDO)"
echo "==========================================

read -p "Introduce el nombre de usuario: " USERNAME
if id "$USERNAME" &>/dev/null; then
    echo "El usuario ya existe."
    exit 1
fi
read -p "Introduce el nombre completo: " FULL_NAME

while true; do
    read -s -p "Introduce la contraseña: " PASSWORD; echo ""
    read -s -p "Confirma la contraseña: " PASSWORD_CONFIRM; echo ""
    if [ "$PASSWORD" != "$PASSWORD_CONFIRM" ]; then
        echo "Las contraseñas no coinciden."
        continue
    fi
    if validar_password "$PASSWORD"; then break; fi
done

read -p "¿Deseas asignar cuotas de disco? (s/n): " ASIGNAR_CUOTA
if [[ "$ASIGNAR_CUOTA" =~ ^[Ss]$ ]]; then
    read -p "Límite Soft (KB): " Q_SOFT
    read -p "Límite Hard (KB): " Q_HARD
    read -p "¿Cambiar periodo de gracia? (s/n): " CAMBIAR_GRACIA
    if [[ "$CAMBIAR_GRACIA" =~ ^[Ss]$ ]]; then
        read -p "Periodo (ej: 7days): " GRACE_PERIOD
    fi
fi

read -p "¿El usuario podrá usar sudo? (s/n): " QUIERE_SUDO
if [[ "$QUIERE_SUDO" =~ ^[Ss]$ ]]; then
    echo "--- Configuración de Sudo ---"
    echo "1) Todos los comandos (ALL)"
    echo "2) Comandos específicos (separados por coma, ej: /usr/bin/apt, /usr/bin/systemctl)"
    read -p "Selecciona una opción (1 o 2): " OP_SUDO
    
    if [ "$OP_SUDO" == "1" ]; then
        SUDO_CMDS="ALL"
    else
        read -p "Introduce los comandos (ruta completa): " SUDO_CMDS
    fi
fi

echo "Procesando..."

useradd -m -c "$FULL_NAME" -s /bin/bash "$USERNAME"
echo "$USERNAME:$PASSWORD" | chpasswd

if [ $? -eq 0 ]; then
    # Aplicar Cuotas
    if [[ "$ASIGNAR_CUOTA" =~ ^[Ss]$ ]]; then
        setquota -u "$USERNAME" "$Q_SOFT" "$Q_HARD" 0 0 /home
        [ ! -z "$GRACE_PERIOD" ] && setquota -t "$GRACE_PERIOD" "$GRACE_PERIOD" /home
    fi

    # Aplicar Sudo
    if [[ "$QUIERE_SUDO" =~ ^[Ss]$ ]]; then
        # Creamos un archivo individual en sudoers.d
        SUDO_FILE="/etc/sudoers.d/user_$USERNAME"
        echo "$USERNAME ALL=(ALL:ALL) $SUDO_CMDS" > "$SUDO_FILE"
        chmod 440 "$SUDO_FILE" # Permisos estrictos obligatorios para sudoers
        echo "Permisos sudo configurados en $SUDO_FILE"
    fi

    echo "------------------------------------------"
    echo "¡Usuario '$USERNAME' creado exitosamente!"
else
    echo "Ocurrió un error inesperado."
    exit 1
fi
